{
  "appId": "com.findmyspace.app",
  "appName": "FindMySpace",
  "webDir": "dist",
  "android": {
    "javaVersion": "17"
  },
  "plugins": {
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com"]
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0E3F63",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}