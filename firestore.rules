rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().isAdmin == true;
    }

    function isLandlord() {
      return isSignedIn() && userDoc().role == 'landlord';
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if request.auth.uid == userId
                    && !('isAdmin' in request.resource.data);
      allow update: if request.auth.uid == userId
                    && !('isAdmin' in request.resource.data)
                    && !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys());

      allow update: if isAdmin();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if resource.data.status == 'approved' || isAdmin()
                  || (isSignedIn() && resource.data.landlordId == request.auth.uid);

      allow create: if isLandlord()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.landlordId == request.auth.uid;

      allow update: if isSignedIn()
                    && resource.data.landlordId == request.auth.uid
                    && !('status' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('landlordId' in request.resource.data.diff(resource.data).affectedKeys());

      // Submitting or editing a review: signed-in user may only touch
      // reviews, rating, and numberOfReviews, and the array may only
      // grow or shrink by 1 at a time (no bulk overwrites).
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['reviews', 'rating', 'numberOfReviews'])
                    && request.resource.data.reviews.size() >= resource.data.reviews.size() - 1
                    && request.resource.data.reviews.size() <= resource.data.reviews.size() + 1;

      // Vote updates: signed-in user may only touch reviews (vote counts),
      // and the array size must stay exactly the same — no additions or deletions.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['reviews'])
                    && request.resource.data.reviews.size() == resource.data.reviews.size();

      allow update: if isAdmin();
      allow delete: if isAdmin()
                    || (isLandlord() && resource.data.landlordId == request.auth.uid);
    }
  }
}