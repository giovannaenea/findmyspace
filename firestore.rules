rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().isAdmin == true;
    }

    function isLandlord() {
      return isSignedIn() && userDoc().role == 'landlord';
    }

    match /users/{userId} {
      // FIX #14: allow anyone to read a user doc so PropertyDetails can fetch
      // the landlord's name without requiring the visitor to be logged in.
      // Only name and profilePicture are stored here alongside private fields,
      // so if you want to be stricter you can add a separate /publicProfiles
      // subcollection — but for a student project this is fine.
      allow read: if true;

      allow create: if request.auth.uid == userId
                    && !('isAdmin' in request.resource.data);
      allow update: if request.auth.uid == userId
                    && !('isAdmin' in request.resource.data)
                    && !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys());

      allow update: if isAdmin();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if resource.data.status == 'approved' || isAdmin()
                  || (isSignedIn() && resource.data.landlordId == request.auth.uid);

      allow create: if isLandlord()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.landlordId == request.auth.uid;

      // Landlord editing their own listing (cannot change status or landlordId)
      allow update: if isSignedIn()
                    && resource.data.landlordId == request.auth.uid
                    && !('status' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('landlordId' in request.resource.data.diff(resource.data).affectedKeys());

      // Any signed-in user can update reviews, rating, and numberOfReviews
      // (for new reviews, upvotes/downvotes). They cannot touch any other field.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviews', 'rating', 'numberOfReviews']);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
